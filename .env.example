APP_NAME=OneMallX
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Public URL of this Laravel API (used for URL generation, mail, etc.)
APP_URL=http://localhost:8000

# Optional: public URL for stored files (/storage/...). On a VPS use http://YOUR_IP:PORT or your domain.
# If unset, APP_URL is used. Set this when APP_URL is localhost inside Docker but clients use the server IP.
# PUBLIC_DISK_URL=http://72.62.42.213:8010

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (this project uses MySQL in production; sqlite works for quick local try) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=onemallx
DB_USERNAME=root
DB_PASSWORD=

# For SQLite instead, comment the block above and use:
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Spatie permission cache: use "array" so DB role/permission edits apply immediately (no artisan reset).
# Leave unset to use CACHE_STORE; after manual DB changes run: php artisan permission:cache-reset
# PERMISSION_CACHE_STORE=array

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail (registration OTP + subscription request approved/rejected) ---
# Use smtp on server; log or array driver for local testing
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Sanctum (SPA / frontend on another origin: list all allowed frontend hosts) ---
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000

# --- Email links (optional): full URLs for buttons in approval/rejection emails ---
FRONTEND_LOGIN_URL=
FRONTEND_SUPPORT_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
